# === LLM Configuration ===
# Default model if not specified when calling get_llm()
LLM_MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# HuggingFace token (required for gated models)
HF_TOKEN=

# === Data Paths ===
# Override default Kaggle paths for local development
# MRCD_DATA_DIR=./data
# MRCD_MODEL_PATH=./models/roberta-fine-v2

# === SLM Backend ===
# Options: "hf" (HuggingFace) or "vllm"
SLM_BACKEND=hf

# === Debug ===
# Set path to enable retrieval debug logging (leave empty to disable)
# MRCD_RETRIEVAL_DEBUG_CSV=./logs/retrieval_debug.csv
